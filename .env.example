# Configuration Firebase pour Netthex

Remplacez les valeurs suivantes dans votre projet Firebase:

VITE_FIREBASE_API_KEY=votre_api_key
VITE_FIREBASE_AUTH_DOMAIN=votre_app.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://votre_app.firebaseio.com
VITE_FIREBASE_PROJECT_ID=votre_project_id
VITE_FIREBASE_STORAGE_BUCKET=votre_app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=votre_sender_id
VITE_FIREBASE_APP_ID=votre_app_id

# Configuration Serveur Socket.io
PORT=3001
CLIENT_URL=http://localhost:5173
VITE_SOCKET_URL=http://localhost:3001

# Configuration Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=votre_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=votre_unsigned_upload_preset
